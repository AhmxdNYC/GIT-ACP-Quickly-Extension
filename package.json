{
  "name": "acp-git-commands",
  "displayName": "Git ACP Quickly Add, Commit & Push",
  "publisher": "AhmadNYC",
  "description": "Adds a custom function to your shell configuration to Git Add, Commit & Push with a single command!",
  "repository": {
    "type": "git",
    "url": "https://github.com/AhmxdNYC/GIT-ACP-Quickly-Extension"
  },
  "icon": "images/icon.ico",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "configuration": {
    "type": "object",
    "title": "ACP Git Commands Settings",
    "properties": {
      "acpGitCommands.shellType": {
        "type": "string",
        "default": "",
        "enum": [
          "bash",
          "zsh",
          "fish"
        ],
        "description": "Specify your shell type if it is not auto-detected (bash, zsh, or fish)."
      }
    }
  },
  "activationEvents": [
    "workspaceContains:.git/config"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "acp-git-commands.installACPCommand",
        "title": "Install ACP Command"
      },
      {
        "command": "extension.acpCommand",
        "title": "Quick Push"
      }
    ],
    "configuration": {
      "title": "Git Status Configuration",
      "properties": {
        "gitStatus.fetchInterval": {
          "type": "number",
          "default": 300000,
          "description": "Interval in milliseconds at which to refresh the Git status. Set to 0 to disable."
        }
      }
    },
    "keybindings": [
      {
        "command": "extension.acpCommand",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      }
    ]
  },
  "scripts": {
    "compile": "webpack --mode production",
    "compile:dev": "webpack --mode development",
    "compile:test": "tsc -p tsconfig.test.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "pretest": "npm run compile:test",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.88.0",
    "@vscode/test-cli": "^0.0.8",
    "@vscode/test-electron": "^2.3.9",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {}
}
